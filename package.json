{
  "name": "saas-platform",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "test:mutation": "stryker run",
    "test:arch": "bash tooling/scripts/check-architecture.sh && vitest run --config tooling/tests/vitest.arch.config.ts",
    "test:arch:vitest": "vitest run --config tooling/tests/vitest.arch.config.ts",
    "check:deps": "node tooling/scripts/check-dependencies.mjs",
    "check:circular": "madge --circular --extensions ts,tsx packages/ modules/ apps/",
    "check:depcruise": "depcruise --config .dependency-cruiser.mjs --output-type err packages/ modules/ apps/",
    "create:module": "bash tooling/scripts/create-module.sh",
    "knip": "knip",
    "create:vertical": "bash tooling/scripts/create-vertical.sh",
    "staging:up": "bash scripts/staging-up.sh",
    "staging:down": "bash scripts/staging-down.sh",
    "staging:reset": "bash scripts/staging-reset.sh",
    "staging:dev": "bash scripts/staging-dev.sh",
    "staging:build": "bash scripts/staging-build.sh",
    "staging:db:push": "bash scripts/staging-db-push.sh",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.18.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.18.0",
    "eslint-plugin-boundaries": "^4.2.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.0",
    "knip": "^5.86.0",
    "lint-staged": "^15.3.0",
    "madge": "^8.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
