# AISOGEN — SEO/GEO/AISO Capability Framework
# Shows how features support each step in the value chain

direction: right

title: {
  label: "AISOGEN — Full-Service SEO/GEO/AISO Capability Framework"
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

