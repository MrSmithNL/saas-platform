features: "AISOGEN — Three Features In Scope" {
  style: {
    fill: "#ECEFF1"
    stroke: "#607D8B"
    font-size: 16
    bold: true
    border-radius: 10
  }

  auditor: "SEO/GEO/AISO Auditor" {
    style: { fill: "#E3F2FD"; font-size: 13; bold: true; border-radius: 6 }
    label: "SEO/GEO/AISO Auditor\n───────────────────\nDomains: A + D + E\n35 sub-processes\nStatus: 3 skills, 5 recipes"
  }

  generator: "Automated Article Generator" {
    style: { fill: "#E8F5E9"; font-size: 13; bold: true; border-radius: 6 }
    label: "Automated Article Generator\n─────────────────────────\nDomains: B (+ A for research)\n15 sub-processes\nStatus: Strategy skill built"
  }

  authority_builder: "External Authority Builder" {
    style: { fill: "#FFF3E0"; font-size: 13; bold: true; border-radius: 6 }
    label: "External Authority Builder\n────────────────────────\nDomains: C (+ E for tracking)\n17 sub-processes\nStatus: Research complete"
  }
}

# Feature connections to domains
features.auditor -> discover: "Audits" {
  style: { stroke: "#2196F3"; stroke-dash: 3 }
}
features.auditor -> optimise: "Scores" {
  style: { stroke: "#9C27B0"; stroke-dash: 3 }
}
features.auditor -> measure: "Tracks" {
  style: { stroke: "#E91E63"; stroke-dash: 3 }
}

features.generator -> create: "Creates" {
  style: { stroke: "#4CAF50"; stroke-dash: 3 }
}
features.generator -> discover: "Researches" {
  style: { stroke: "#2196F3"; stroke-dash: 3 }
}

features.authority_builder -> authority: "Builds" {
  style: { stroke: "#FF9800"; stroke-dash: 3 }
}
features.authority_builder -> measure: "Monitors" {
  style: { stroke: "#E91E63"; stroke-dash: 3 }
}

