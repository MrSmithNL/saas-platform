# ═══════════════════════════════════════════════════════════
# VALUE CHAIN FLOW (left to right)
# ═══════════════════════════════════════════════════════════

discover -> create: "Gaps identified" {
  style: { stroke: "#666"; stroke-width: 3; font-size: 12 }
}
create -> authority: "Content published" {
  style: { stroke: "#666"; stroke-width: 3; font-size: 12 }
}
authority -> optimise: "Authority signals" {
  style: { stroke: "#666"; stroke-width: 3; font-size: 12 }
}
optimise -> measure: "Optimised" {
  style: { stroke: "#666"; stroke-width: 3; font-size: 12 }
}

# ═══════════════════════════════════════════════════════════
# FEEDBACK LOOP — Measure feeds back to Discover
# ═══════════════════════════════════════════════════════════

measure -> discover: "Re-audit cycle\n(autonomous)" {
  style: {
    stroke: "#E91E63"
    stroke-width: 3
    stroke-dash: 5
    font-size: 12
    font-color: "#E91E63"
  }
}

# ═══════════════════════════════════════════════════════════
# AISOGEN THREE FEATURES — Which domains they cover
